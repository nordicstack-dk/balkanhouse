# Database (Neon Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Payload
PAYLOAD_SECRET=your-payload-secret-min-32-chars

# App URL (local dev)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Flatpay (payments) — add when integrating checkout
FLATPAY_API_KEY=
FLATPAY_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=

# Vercel Blob — enables cloud media storage when set (auto-set on Vercel after adding Blob).
# Without this token, Payload falls back to local ./media uploads (fine for local dev).
# Copy from Vercel project → Storage → Blob → .env.local snippet.
BLOB_READ_WRITE_TOKEN=
# Use "private" for private Blob stores (default), or "public" for public stores.
BLOB_ACCESS=private
