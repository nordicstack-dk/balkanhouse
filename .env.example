# Database (Neon Postgres)
# Use sslmode=verify-full: pg treats require/prefer/verify-ca as verify-full today
# but pg v9 will weaken them, so be explicit. (The app normalizes require→verify-full
# at runtime regardless, so an existing sslmode=require URL keeps working.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full

# Payload
PAYLOAD_SECRET=your-payload-secret-min-32-chars

# Public app URL (payment return links, emails). On Vercel set to your production domain.
# Local dev:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Vercel production example:
# NEXT_PUBLIC_SERVER_URL=https://your-domain.vercel.app

# Flatpay / Frisbii (payments)
# Frisbii sandbox and production keys both go here — the provider is Frisbii; the env name is FLATPAY_* for legacy naming.
# FRISBII_API_KEY is also accepted as a fallback alias.
FLATPAY_API_KEY=
# Webhook secret from Frisbii → Configuration → Webhooks → Secret key (NOT the API key).
# If wrong or missing, webhooks are rejected (401) or accepted unsigned (when unset).
FLATPAY_WEBHOOK_SECRET=
# Production webhook URL (configure in Frisbii admin):
#   https://<your-vercel-domain>/api/webhooks/flatpay
# Subscribe to invoice events: invoice_authorized, invoice_settled, invoice_failed
# Optional overrides (Frisbii sandbox defaults)
# FLATPAY_API_BASE_URL=https://api.frisbii.com/v1
# FLATPAY_CHECKOUT_API_BASE_URL=https://checkout-api.frisbii.com/v1

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# Resend webhook signing secret — enables email delivery tracking (delivered/opened/clicked)
# on the order page. In Resend → Webhooks add an endpoint pointing at
#   https://<your-domain>/api/webhooks/resend
# subscribe to the email.* events, and copy its Signing Secret here.
# Open/click tracking also requires a verified sending domain with tracking enabled.
RESEND_WEBHOOK_SECRET=

# External cron (cron-job.org) — expire stale payment links
# Generate a long random string; use the same value in cron-job.org Authorization header.
CRON_SECRET=
# Hours after sending a payment link before the order is auto-cancelled (default 72)
PAYMENT_LINK_EXPIRY_HOURS=72

# Vercel Blob — enables cloud media storage when set (auto-set on Vercel after adding Blob).
# Without this token, Payload falls back to local ./media uploads (fine for local dev).
# Copy from Vercel project → Storage → Blob → .env.local snippet.
BLOB_READ_WRITE_TOKEN=
# Recommended for product images: "public" (direct *.public.blob.vercel-storage.com URLs).
# Use "private" only for private Blob stores; storefront then serves images via /api/media/file/.
BLOB_ACCESS=public
